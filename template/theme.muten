# The project's design SCALE - muten emits these as :root CSS custom properties (e.g. --space-md,
# --font-lg) for your CSS / class("…") to consume. Add/rename steps freely.
theme {
  space       { xs "4px"  sm "8px"  md "16px"  lg "24px"  xl "32px" }
  font        { sm "13px"  md "15px"  lg "20px"  xl "28px" }
  weight      { medium "500"  bold "700" }
  leading     { tight "1.2"  normal "1.5"  loose "1.8" }
  breakpoints { sm "640px"  md "768px"  lg "1024px" }
}
